# Tavily Search API key (Free tier available at tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# Google Gemini API key (Free tier available at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Groq API key (optional; preferred when set)
# The code also accepts your current custom name: groqapikey.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Business/financial data APIs
# The code also accepts your current custom names:
# financialmodelingprep and Alpha_Vantage.
FINANCIAL_MODELING_PREP_API_KEY=your_fmp_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free

# Optional SQLite checkpointing for persistent LangGraph memory
# Defaults to backend/scratch/langgraph_checkpoints.sqlite when omitted.
SQLITE_DATABASE_PATH=scratch/langgraph_checkpoints.sqlite

# CORS configuration (Default Vite local development URL)
CORS_ORIGINS=http://localhost:5173
